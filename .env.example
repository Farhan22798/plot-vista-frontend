# Copy to .env and adjust for local dev
API_URL=http://192.168.0.105:5000

# CometChat (react-native-config) — same keys in .env.production for release builds
COMETCHAT_APP_ID=
COMETCHAT_REGION=
COMETCHAT_AUTH_KEY=
# Optional: override community group GUID (default in app is golden-city)
COMETCHAT_COMMUNITY_GROUP_ID=
# Optional: override activity notification group GUID (default is golden-city-noti)
COMETCHAT_NOTIFICATION_GROUP_ID=
# Required for Android push token registration in CometChat dashboard
COMETCHAT_FCM_PROVIDER_ID=
